# NAS Dashboard – Environment Configuration
# Copy this file to .env and fill in values for your environment.
# The dashboard works without any of these set (uses defaults).

# Server port (default: 3001)
PORT=3001

# CORS origin for the React dev server (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# SMTP settings for alert emails
# Leave unset to disable email (alerts still run but skip sending)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=nas-dashboard@localhost
